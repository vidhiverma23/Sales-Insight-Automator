# === Sales Insight Automator — Backend Configuration ===

# --- AI Engine ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# --- Email Service (Resend) ---
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=Sales Automator <onboarding@resend.dev>

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Security ---
API_KEY=                 # Leave empty to disable API key auth
RATE_LIMIT=5/minute
MAX_FILE_SIZE_MB=10

# --- App ---
DEBUG=false
